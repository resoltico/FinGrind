# Exclude everything — the Docker image only needs the pre-built fat JAR.
# Build the JAR first: ./gradlew :cli:shadowJar
**

# Allow only the fat JAR produced by the Shadow plugin.
!gradle.properties
!scripts/
!cli/build/libs/
!cli/build/libs/*.jar
!third_party/
!third_party/sqlite/
!third_party/sqlite/sqlite-amalgamation-3530000/
!third_party/sqlite/sqlite-amalgamation-3530000/sqlite3.c
!third_party/sqlite/sqlite-amalgamation-3530000/sqlite3.h
!third_party/sqlite/sqlite-amalgamation-3530000/sqlite3ext.h
